  "keyFeatures": [
    "Daily menu display with calorie information",
    "User authentication via Google OAuth",
    "Favorites system with email notifications",
    "Calorie tracking and consumption logs",
    "Like/dislike reactions with rate limiting",
    "Menu sharing and AI prompt generation",
    "PWA support with offline capabilities",
    "Automated daily menu scraping via GitHub Actions",
    "Dark/light theme support",
    "Responsive mobile and desktop design"
  ],
  "publicApiSurface": [
    "GET /api/menu/date/:date",
    "GET /api/meal/:id",
    "GET /api/reactions?date=YYYY-MM-DD",
    "POST /api/reactions",
    "GET /api/favorites",
    "POST /api/favorites",
    "GET /api/email-preferences",
